{
  "name": "backend-logger",
  "version": "0.2.0",
  "description": "Fast, zero-config HTTP request logger middleware for Express and Node.js. Structured JSON logs, colored console output, file transport, automatic secret redaction, request ID correlation, and full TypeScript support. A lightweight, dependency-free alternative to morgan, pino-http, and express-winston.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "express",
    "express-middleware",
    "express-logger",
    "express-request-logger",
    "express5",
    "express4",
    "request-logger",
    "http-logger",
    "http-request-logger",
    "http-logging",
    "api-logger",
    "api-logging",
    "access-log",
    "access-logger",
    "logger",
    "logging",
    "nodejs",
    "node-logger",
    "middleware",
    "structured-logging",
    "structured-logs",
    "json-logs",
    "json-logger",
    "json-logging",
    "ndjson",
    "redaction",
    "log-redaction",
    "secret-redaction",
    "pii-redaction",
    "request-id",
    "correlation-id",
    "trace-id",
    "tracing",
    "observability",
    "monitoring",
    "morgan",
    "morgan-alternative",
    "pino",
    "pino-http",
    "winston",
    "winston-alternative",
    "typescript",
    "ts",
    "color",
    "colored-logs",
    "file-logger",
    "stdout",
    "debug",
    "production-logger",
    "zero-config"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Satyam12x/req-log.git"
  },
  "bugs": {
    "url": "https://github.com/Satyam12x/req-log/issues"
  },
  "homepage": "https://github.com/Satyam12x/req-log#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "express": "^5.2.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
